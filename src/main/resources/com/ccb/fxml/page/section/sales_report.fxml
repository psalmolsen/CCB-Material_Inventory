<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:id="salesSection"
      styleClass="section-content"
      VBox.vgrow="ALWAYS"
      visible="false"
      managed="false">

    <Label text="Pellets L-Sales Report" styleClass="section-title"/>
    <HBox styleClass="stat-cards" spacing="14">
        <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
            <Label fx:id="salesTotalCount" text="0" styleClass="stat-number"/>
            <Label text="Qty" styleClass="stat-qty"/>
            <Label text="TOTAL SOLD" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-red" HBox.hgrow="ALWAYS">
            <Label fx:id="salesMonthCount" text="0" styleClass="stat-number"/>
            <Label text="Qty" styleClass="stat-qty"/>
            <Label text="THIS MONTH" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
            <Label fx:id="salesTodayCount" text="0" styleClass="stat-number"/>
            <Label text="Qty" styleClass="stat-qty"/>
            <Label text="TODAY" styleClass="stat-label"/>
        </VBox>
    </HBox>
    <VBox styleClass="panel" VBox.vgrow="ALWAYS">
        <Label text="Sales Records" styleClass="panel-title"/>
        <Label text="Pellets L-sales report will appear here." styleClass="placeholder-text"/>
    </VBox>
</VBox>
