<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ccb.controller.page.PelletsLSalesController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="oring-scroll"
            style="-fx-background-color: #F4F5F7;">
    <content>
        <VBox spacing="14" style="-fx-background-color: #F4F5F7; -fx-padding: 16;" VBox.vgrow="ALWAYS">
            
            <!-- Top Bar -->
            <HBox fx:id="pelletsLSalesTopbar" alignment="CENTER_LEFT" spacing="12" 
                  style="-fx-background-color: #FFFFFF; -fx-padding: 12 16; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <!-- Left: Red bar and Title -->
                    <Region fx:id="titleAccent" style="-fx-background-color: #C0392B; -fx-pref-width: 4; -fx-pref-height: 22; -fx-min-width: 4; -fx-max-width: 4;"/>
                    <Label text="Pellets L-Sales" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A2535;"/>
                </HBox>
                
                <!-- Right: Controls -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField" promptText="Search records..." 
                               style="-fx-background-color: #F4F5F7; -fx-background-radius: 7; -fx-border-color: #DDE1E7; -fx-border-radius: 7; -fx-border-width: 1; -fx-padding: 8 12; -fx-prompt-text-fill: #9CA3AF; -fx-text-fill: #1A2535; -fx-font-size: 12px;" 
                               prefWidth="220"/>
                    <ComboBox fx:id="sackFilterComboBox" 
                               style="-fx-background-color: #1B2A3B; -fx-text-fill: #FFFFFF; -fx-background-radius: 7; -fx-border-radius: 7; -fx-border-color: #1B2A3B; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 14; -fx-cursor: hand;" 
                               prefWidth="280"/>
                    <Button fx:id="refreshButton" text="🔄" 
                            style="-fx-background-color: #1B2A3B; -fx-text-fill: #FFFFFF; -fx-background-radius: 9; -fx-border-radius: 9; -fx-border-color: #1B2A3B; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-cursor: hand;" 
                            mnemonicParsing="false"/>
                </HBox>
            </HBox>

            <!-- Loading State -->
            <VBox fx:id="loadingState" alignment="CENTER" spacing="10" 
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 22 18;">
                <ProgressIndicator maxWidth="36" maxHeight="36"/>
                <Label text="Loading Pellets L-Sales data..." style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Error State -->
            <VBox fx:id="errorState" alignment="CENTER" spacing="10" visible="false" managed="false"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 22 18;">
                <Label fx:id="errorMessage" text="Unable to load Pellets L-Sales data." wrapText="true" 
                       style="-fx-text-fill: #C0392B; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <Button fx:id="retryButton" text="Retry" 
                        style="-fx-background-color: #1B2A3B; -fx-text-fill: #FFFFFF; -fx-background-radius: 8; -fx-border-radius: 8; -fx-font-weight: bold; -fx-padding: 6 12; -fx-cursor: hand;"/>
            </VBox>

            <!-- Empty State -->
            <VBox fx:id="emptyState" alignment="CENTER" spacing="8" visible="false" managed="false"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 12; -fx-padding: 22 18;">
                <Label text="No Pellets L-Sales records found." 
                       style="-fx-text-fill: #1A2535; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Label text="Try a different month filter or refresh the sheet." wrapText="true" 
                       style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Data State (Dynamic content will be built inside here) -->
            <VBox fx:id="dataState" spacing="14" visible="false" managed="false">

                <!-- Time Slot Detail Panel -->
                <VBox fx:id="slotDetailPanel" spacing="0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 0.5; -fx-border-radius: 12px; -fx-background-radius: 12px;">

                    <!-- SECTION 1: PANEL HEADER -->
                    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #F9FAFB; -fx-padding: 12 16; -fx-border-color: #F0F2F5; -fx-border-width: 0 0 1 0;">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Region style="-fx-background-color: #1F5FA6; -fx-pref-width: 3; -fx-pref-height: 14;"/>
                            <VBox spacing="2">
                                <Label text="Good vs Rejected — time slot view" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A2535;"/>
                                <Label text="Use ‹ › to browse each time slot within the selected sack" style="-fx-font-size: 10px; -fx-text-fill: #9CA3AF;"/>
                            </VBox>
                        </HBox>
                    </HBox>

                    <!-- SECTION 2: TIME SLOT NAVIGATOR BAR -->
                    <HBox alignment="CENTER" spacing="0" style="-fx-background-color: #FFFFFF; -fx-padding: 10 16; -fx-border-color: #F0F2F5; -fx-border-width: 0 0 1 0;">
                        <Button fx:id="prevSlotBtn" text="‹" onAction="#onPrevSlot" styleClass="slot-nav-arrow"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <VBox alignment="CENTER" spacing="4">
                            <Label fx:id="slotTimeLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A2535;"/>
                            <Label fx:id="slotDateLabel" style="-fx-font-size: 10px; -fx-text-fill: #9CA3AF;"/>
                            <Label fx:id="slotCounterLabel" style="-fx-font-size: 10px; -fx-text-fill: #9CA3AF;"/>
                            <HBox fx:id="slotDotsBox" alignment="CENTER" spacing="4"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="nextSlotBtn" text="›" onAction="#onNextSlot" styleClass="slot-nav-arrow"/>
                    </HBox>

                    <!-- SECTION 3: MINI SUMMARY ROW -->
                    <HBox spacing="8" style="-fx-background-color: #F9FAFB; -fx-padding: 10 14; -fx-border-color: #F0F2F5; -fx-border-width: 0 0 1 0;">
                        <HBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8 12;">
                            <VBox spacing="3" alignment="CENTER">
                                <Label text="GOOD THIS SLOT" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF; -fx-letter-spacing: 0.6px;"/>
                                <Label fx:id="slotGoodLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F5FA6;"/>
                            </VBox>
                        </HBox>
                        <HBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8 12;">
                            <VBox spacing="3" alignment="CENTER">
                                <Label text="REJECTED THIS SLOT" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF; -fx-letter-spacing: 0.6px;"/>
                                <Label fx:id="slotRejLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #C0392B;"/>
                            </VBox>
                        </HBox>
                        <HBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8 12;">
                            <VBox spacing="3" alignment="CENTER">
                                <Label text="REJECT RATE" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF; -fx-letter-spacing: 0.6px;"/>
                                <Label fx:id="slotRateLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>
                        <HBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-width: 1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8 12;">
                            <VBox spacing="3" alignment="CENTER">
                                <Label text="SACK TOTAL GOOD" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF; -fx-letter-spacing: 0.6px;"/>
                                <Label fx:id="sackTotalGoodLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #6B7280;"/>
                            </VBox>
                        </HBox>
                    </HBox>

                    <!-- SECTION 4: BAR CHART -->
                    <VBox spacing="0" style="-fx-padding: 10 14 14;">
                        <HBox spacing="14" style="-fx-padding: 0 0 8 0;">
                            <HBox spacing="6" alignment="CENTER">
                                <Circle radius="4.5" fill="#1F5FA6"/>
                                <Label text="Good (shot blasting good)" style="-fx-font-size: 10px; -fx-text-fill: #6B7280;"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER">
                                <Circle radius="4.5" fill="#C0392B"/>
                                <Label text="Rejected (shot blasting reject)" style="-fx-font-size: 10px; -fx-text-fill: #6B7280;"/>
                            </HBox>
                        </HBox>
                        <BarChart fx:id="slotBarChart" styleClass="slot-bar-chart" prefHeight="180" legendVisible="false" animated="false">
                            <xAxis>
                                <CategoryAxis fx:id="slotXAxis" style="-fx-tick-label-fill: #1A2535; -fx-tick-label-font-size: 13px; -fx-tick-label-font-weight: bold;"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="slotYAxis" style="-fx-tick-label-fill: #9CA3AF; -fx-tick-label-font-size: 10px;" lowerBound="0" autoRanging="true"/>
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <!-- SECTION 5: CONTEXT STRIP -->
                    <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <HBox fx:id="contextStrip" spacing="4" style="-fx-background-color: #FFFFFF; -fx-padding: 8 14; -fx-border-color: #F0F2F5; -fx-border-width: 1 0 0 0;"/>
                    </ScrollPane>

                </VBox>

            </VBox>
            
        </VBox>
    </content>
</ScrollPane>
