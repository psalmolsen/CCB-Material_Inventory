<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:id="oringSection"
      styleClass="section-content"
      VBox.vgrow="ALWAYS"
      visible="false"
      managed="false">

    <Label text="O-Ring Overview" styleClass="section-title"/>
    <HBox styleClass="stat-cards" spacing="14">
        <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
            <Label fx:id="oringTotalCount" text="0" styleClass="stat-number"/>
            <Label text="Qty" styleClass="stat-qty"/>
            <Label text="TOTAL O-RINGS" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-red" HBox.hgrow="ALWAYS">
            <Label fx:id="oringLowCount" text="0" styleClass="stat-number"/>
            <Label text="Qty" styleClass="stat-qty"/>
            <Label text="LOW STOCK" styleClass="stat-label"/>
        </VBox>
        <VBox styleClass="stat-card stat-yellow" HBox.hgrow="ALWAYS">
            <Label fx:id="oringIssuedCount" text="0" styleClass="stat-number"/>
            <Label text="Qty" styleClass="stat-qty"/>
            <Label text="ISSUED TODAY" styleClass="stat-label"/>
        </VBox>
    </HBox>
    <VBox styleClass="panel" VBox.vgrow="ALWAYS">
        <Label text="O-Ring Records" styleClass="panel-title"/>
        <Label text="O-ring monitoring table will appear here." styleClass="placeholder-text"/>
    </VBox>
</VBox>
