<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ccb.controller.modal.MaterialMonthOutController"
      prefWidth="560" prefHeight="720"
      styleClass="dialog-shell">

    <VBox styleClass="dialog-header">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="materialLabel" text="Material" styleClass="dialog-title"/>
                <Label fx:id="dialogSubtitle" text="" styleClass="dialog-subtitle"/>
            </VBox>
            <Button text="Close" onAction="#closeDialog" styleClass="btn-secondary"/>
        </HBox>
    </VBox>

    <VBox styleClass="dialog-body" VBox.vgrow="ALWAYS" spacing="14">

        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar-strip toolbar-card">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Month" styleClass="field-caption"/>
                <ComboBox fx:id="monthComboBox" prefWidth="140" styleClass="month-picker"/>
            </VBox>
            <VBox alignment="CENTER_RIGHT" spacing="4" styleClass="summary-pill">
                <Label text="TOTAL ISSUED" styleClass="summary-label"/>
                <Label fx:id="totalIssuedLabel" text="0000" styleClass="summary-value"/>
            </VBox>
        </HBox>

        <HBox spacing="12" styleClass="month-summary-row">
            <VBox styleClass="month-summary-card" HBox.hgrow="ALWAYS">
                <Label text="PEAK DAY" styleClass="month-summary-label"/>
                <Label fx:id="peakDayLabel" text="--" styleClass="month-summary-value"/>
            </VBox>
            <VBox styleClass="month-summary-card" HBox.hgrow="ALWAYS">
                <Label text="ACTIVE DAYS" styleClass="month-summary-label"/>
                <Label fx:id="activeDaysLabel" text="0" styleClass="month-summary-value"/>
            </VBox>
            <VBox styleClass="month-summary-card" HBox.hgrow="ALWAYS">
                <Label text="AVERAGE / ACTIVE DAY" styleClass="month-summary-label"/>
                <Label fx:id="averageDayLabel" text="0" styleClass="month-summary-value"/>
            </VBox>
        </HBox>

        <Label fx:id="errorLabel" visible="false" managed="false" styleClass="inline-error"/>

        <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS"
                    styleClass="glass-scroll" hbarPolicy="NEVER">
            <content>
                <VBox styleClass="day-list-shell">
                    <VBox fx:id="daysBox" spacing="8" styleClass="day-list-stack"/>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>
</VBox>
