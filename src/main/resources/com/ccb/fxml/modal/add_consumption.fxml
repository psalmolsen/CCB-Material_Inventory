<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.ccb.controller.modal.AddConsumptionController"
           prefWidth="1200" prefHeight="780"
           style="-fx-background-color: transparent;">

    <VBox maxWidth="1180" prefWidth="1180" spacing="0" styleClass="consumption-dialog-shell">

        <HBox styleClass="consumption-dialog-header" alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Station Consumption" styleClass="consumption-dialog-eyebrow"/>
                <Label text="Record what each station used and automatically update the live inventory balance."
                       wrapText="true" styleClass="consumption-dialog-title"/>
                <Label text="One tap for the station, one tap for the material, then type the receiver."
                       wrapText="true" styleClass="consumption-dialog-subtitle"/>
            </VBox>

            <VBox alignment="CENTER_RIGHT" spacing="6">
                <Label fx:id="dateLabel" text="Today" styleClass="consumption-date-pill"/>
                <Button text="Close" onAction="#closeDialog" styleClass="consumption-close-button"/>
            </VBox>
        </HBox>

        <HBox spacing="16" styleClass="consumption-body">

            <VBox spacing="14" HBox.hgrow="ALWAYS" styleClass="consumption-left-column">

                <VBox spacing="10" styleClass="consumption-panel">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Region styleClass="consumption-panel-accent"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Choose Station" styleClass="consumption-panel-title"/>
                            <Label text="Pick the station card that received the material." styleClass="consumption-panel-subtitle"/>
                        </VBox>
                    </HBox>
                    <FlowPane fx:id="stationCardsHost" hgap="10" vgap="10" prefWrapLength="760" styleClass="consumption-station-grid"/>
                </VBox>

                <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="consumption-panel">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Region styleClass="consumption-panel-accent consumption-panel-accent-blue"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Choose Material" styleClass="consumption-panel-title"/>
                            <Label text="Search the inventory list, then click a card to select it." styleClass="consumption-panel-subtitle"/>
                        </VBox>
                        <TextField fx:id="searchField" promptText="Search code, description, or UOM" prefWidth="300"
                                   styleClass="consumption-search-field"/>
                    </HBox>

                    <StackPane VBox.vgrow="ALWAYS" styleClass="consumption-material-shell">
                        <ListView fx:id="materialsList" styleClass="consumption-material-list" StackPane.alignment="CENTER"/>
                        <VBox fx:id="materialsEmptyState" alignment="CENTER" spacing="8" styleClass="consumption-empty-overlay" visible="false" managed="false">
                            <Label text="No materials loaded yet" styleClass="consumption-empty-title"/>
                            <Label text="If the list is empty, the current month sheet may still be loading."
                                   wrapText="true" styleClass="consumption-empty-subtitle"/>
                        </VBox>
                    </StackPane>
                </VBox>
            </VBox>

            <VBox spacing="14" prefWidth="360" maxWidth="360" styleClass="consumption-right-column">

                <VBox spacing="12" styleClass="consumption-panel consumption-summary-panel">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Region styleClass="consumption-panel-accent consumption-panel-accent-red"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Review" styleClass="consumption-panel-title"/>
                            <Label text="The record below updates automatically as you pick values." styleClass="consumption-panel-subtitle"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4" styleClass="consumption-summary-block">
                        <Label text="Station" styleClass="consumption-summary-label"/>
                        <Label fx:id="selectedStationLabel" text="Choose a station" wrapText="true" styleClass="consumption-summary-value"/>
                    </VBox>

                    <VBox spacing="4" styleClass="consumption-summary-block">
                        <Label text="Material" styleClass="consumption-summary-label"/>
                        <Label fx:id="selectedMaterialLabel" text="Choose a material" wrapText="true" styleClass="consumption-summary-value"/>
                        <Label fx:id="selectedMaterialCodeLabel" text="No material selected" styleClass="consumption-summary-meta"/>
                    </VBox>

                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="consumption-summary-block">
                            <Label text="UOM" styleClass="consumption-summary-label"/>
                            <Label fx:id="selectedMaterialUnitLabel" text="UOM: --" styleClass="consumption-summary-meta"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="consumption-summary-block">
                            <Label text="Balance" styleClass="consumption-summary-label"/>
                            <Label fx:id="selectedMaterialBalanceLabel" text="Balance: --" styleClass="consumption-summary-meta"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="consumption-summary-block">
                            <Label text="Unit Cost" styleClass="consumption-summary-label"/>
                            <Label fx:id="selectedMaterialUnitCostLabel" text="Unit cost: --" styleClass="consumption-summary-meta"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="consumption-summary-block consumption-summary-highlight">
                            <Label text="Total Cost" styleClass="consumption-summary-label"/>
                            <Label fx:id="selectedMaterialTotalCostLabel" text="Total cost: --" styleClass="consumption-summary-total"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="12" styleClass="consumption-panel">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Region styleClass="consumption-panel-accent consumption-panel-accent-yellow"/>
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Receiver + Quantity" styleClass="consumption-panel-title"/>
                            <Label text="Receiver can be typed. Quantity stays numeric and live-calculates cost." styleClass="consumption-panel-subtitle"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label text="Received By" styleClass="consumption-field-label"/>
                        <TextField fx:id="receiverField" promptText="Name of the person who received the material"
                                   styleClass="consumption-text-field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Quantity" styleClass="consumption-field-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Button fx:id="minusButton" text="-" styleClass="consumption-step-button"/>
                            <TextField fx:id="quantityField" text="1" prefWidth="110" styleClass="consumption-qty-field"/>
                            <Button fx:id="plusButton" text="+" styleClass="consumption-step-button"/>
                            <Region HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <Label fx:id="errorLabel" text="" visible="false" managed="false" styleClass="consumption-error-text"/>

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button text="Cancel" onAction="#closeDialog" styleClass="consumption-secondary-button"/>
                        <Button fx:id="saveButton" text="Record Consumption" styleClass="consumption-primary-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</StackPane>
