<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ccb.controller.modal.EditMaterialController"
      prefWidth="660" prefHeight="620"
      styleClass="dialog-shell">

    <VBox styleClass="dialog-header dialog-header-alt">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Edit Material Details" styleClass="dialog-title"/>
                <Label text="Update identity, pricing and stock figures for this material." styleClass="dialog-subtitle"/>
            </VBox>
            <Button text="Close" onAction="#closeDialog" styleClass="btn-secondary"/>
        </HBox>
    </VBox>

    <VBox styleClass="dialog-body" VBox.vgrow="ALWAYS" spacing="14">
        <VBox styleClass="hero-panel" spacing="4">
            <Label text="MATERIAL DETAILS EDITOR" styleClass="hero-tag"/>
            <Label text="Edit identity, pricing and inventory figures" styleClass="hero-headline"/>
        </VBox>

        <HBox spacing="14" VBox.vgrow="ALWAYS">
            <VBox styleClass="panel-card editor-panel" HBox.hgrow="ALWAYS" spacing="12">
                <Label text="Material Identity" styleClass="section-kicker"/>
                <GridPane hgap="12" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Date" styleClass="field-caption" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="dateField" GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                    <Label text="Code" styleClass="field-caption" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <TextField fx:id="codeField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Description" styleClass="field-caption" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
                    <TextField fx:id="descriptionField" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2"/>

                    <Label text="UOM" styleClass="field-caption" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="uomField" GridPane.rowIndex="5" GridPane.columnIndex="0"/>

                    <Label text="Price / Unit" styleClass="field-caption" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <TextField fx:id="priceField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>

            <VBox styleClass="panel-card editor-panel" HBox.hgrow="ALWAYS" spacing="12">
                <Label text="Inventory Figures" styleClass="section-kicker"/>
                <GridPane hgap="12" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Initial Stock" styleClass="field-caption" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="initialStockField" GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                    <Label text="Received" styleClass="field-caption" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <TextField fx:id="receivedField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Balance" styleClass="field-caption" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="balanceField" GridPane.rowIndex="3" GridPane.columnIndex="0"/>

                    <Label text="Out Quantity" styleClass="field-caption" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <TextField fx:id="outQuantityField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                </GridPane>

                <Separator style="-fx-opacity: 0.15;" />
                <VBox spacing="8">
                    <Label text="Material Image" styleClass="field-caption"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <StackPane fx:id="thumbFrame" styleClass="material-thumb-frame" prefWidth="54" prefHeight="54" minWidth="54" minHeight="54" maxWidth="54" maxHeight="54" style="-fx-pref-width: 54; -fx-pref-height: 54; -fx-background-radius: 10; -fx-border-radius: 10;">
                            <Label fx:id="thumbFallback" styleClass="material-thumb-fallback" text="M" alignment="CENTER" style="-fx-font-size: 12px;"/>
                            <ImageView fx:id="thumbImageView" fitWidth="48" fitHeight="48" preserveRatio="true" smooth="true"/>
                        </StackPane>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <TextField fx:id="imagePathField" editable="false" promptText="No image selected" style="-fx-font-size: 11px;"/>
                            <Button text="Browse" onAction="#browseImage" styleClass="btn-secondary" style="-fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>

        <Label fx:id="errorLabel" visible="false" managed="false" styleClass="inline-error"/>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="Cancel" onAction="#closeDialog" styleClass="btn-secondary"/>
            <Button text="Save Changes" onAction="#saveChanges" styleClass="btn-add-material"/>
        </HBox>
    </VBox>
</VBox>
