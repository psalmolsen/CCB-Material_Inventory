<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ccb.AddMaterialController"
      style="-fx-background-color: white; -fx-background-radius: 16;"
      prefWidth="420" spacing="0">

    <!-- Header -->
    <HBox style="-fx-background-color: #B71C1C; -fx-background-radius: 16 16 0 0; -fx-padding: 20 24;" alignment="CENTER_LEFT" maxWidth="Infinity">
        <Label text="Add New Material" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <Button text="✕" onAction="#closeDialog"
                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 14px; -fx-cursor: hand; -fx-border-width: 0; -fx-padding: 0;"/>
    </HBox>

    <!-- Form -->
    <VBox style="-fx-padding: 28 24; -fx-spacing: 20;">

        <!-- Code # -->
        <VBox spacing="6">
            <Label text="Code #" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8892b0; -fx-letter-spacing: 0.8px;"/>
            <TextField fx:id="codeField" promptText="e.g. CCB1001"
                       style="-fx-background-color: #f4f6fb; -fx-background-radius: 8; -fx-border-color: #eaedf5; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10 14; -fx-font-size: 13px;"/>
        </VBox>

        <!-- Item Description -->
        <VBox spacing="6">
            <Label text="Item / Description" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8892b0; -fx-letter-spacing: 0.8px;"/>
            <TextField fx:id="descriptionField" promptText="e.g. Cutting Disc (Sunrise) 4 Inch"
                       style="-fx-background-color: #f4f6fb; -fx-background-radius: 8; -fx-border-color: #eaedf5; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10 14; -fx-font-size: 13px;"/>
        </VBox>

        <!-- UOM -->
        <VBox spacing="6">
            <Label text="Unit of Measurement (UOM)" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8892b0; -fx-letter-spacing: 0.8px;"/>
            <ComboBox fx:id="uomComboBox" promptText="Select UOM" maxWidth="Infinity"
                      style="-fx-background-color: #f4f6fb; -fx-background-radius: 8; -fx-border-color: #eaedf5; -fx-border-radius: 8; -fx-border-width: 1; -fx-font-size: 13px;"/>
        </VBox>

        <!-- Price / Unit -->
        <VBox spacing="6">
            <Label text="Price / Unit" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8892b0; -fx-letter-spacing: 0.8px;"/>
            <TextField fx:id="priceField" promptText="e.g. 25.50"
                       style="-fx-background-color: #f4f6fb; -fx-background-radius: 8; -fx-border-color: #eaedf5; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10 14; -fx-font-size: 13px;"/>
        </VBox>

        <!-- Image -->
        <VBox spacing="6">
            <Label text="Material Image" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8892b0; -fx-letter-spacing: 0.8px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="imagePathField" promptText="No image selected" editable="false"
                           style="-fx-background-color: #f4f6fb; -fx-background-radius: 8; -fx-border-color: #eaedf5; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10 14; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
                <Button text="Browse" onAction="#browseImage"
                        style="-fx-background-color: #293A92; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-width: 0;"/>
            </HBox>
        </VBox>

        <!-- Error label -->
        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #B71C1C; -fx-font-size: 11px;" visible="false" managed="false"/>

        <!-- Buttons -->
        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
            <Button text="Cancel" onAction="#closeDialog"
                    style="-fx-background-color: #f4f6fb; -fx-text-fill: #8892b0; -fx-font-size: 13px; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-width: 0;"/>
            <Button text="Save Material" onAction="#saveMaterial"
                    style="-fx-background-color: #293A92; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand; -fx-border-width: 0; -fx-effect: dropshadow(gaussian, rgba(41,58,146,0.30), 10, 0, 0, 3);"/>
        </HBox>

    </VBox>
</VBox>
